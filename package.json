{
  "name": "micro-citas-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Backend Node.js/Express para Micro-Citas",
  "scripts": {
    "check": "biome check .",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,cjs,mjs,jsx,ts,tsx,json}": "biome check --no-errors-on-unmatched"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10"
  }
}
