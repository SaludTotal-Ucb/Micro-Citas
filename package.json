{
  "name": "micro-citas-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Backend Node.js/Express para Micro-Citas",
  "scripts": {
    "check": "biome check .",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
